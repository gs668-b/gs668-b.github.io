                const html = '<div class="conversation-item ' + isActive + '" data-id="' + conv.id + '">' +
                    '<div class="conversation-header">' +
                    '<span class="conversation-user">' + conv.user.name + '</span>' +
                    '<span class="conversation-time">' + conv.lastMessageTime + '</span>' +
                    '</div>' +
                    '<div class="conversation-message">' + conv.lastMessage + '</div>' +
                    '<div class="conversation-footer">' +
                    '<div class="conversation-footer-left">' +
                    '<span class="conversation-status ' + statusClass + '">' + statusText + '</span>' +
                    '<span class="conversation-category">' + categoryText + '</span>' +
                    '</div>' +
                    '</div>' +
                    '</div>';

                $list.append(html);
            });

            // 绑定会话项点击事件
            $('.conversation-item').click(function() {
                const convId = parseInt($(this).data('id'));
                selectConversation(convId);
            });
        }

        // 选择会话
        function selectConversation(convId) {
            const conv = conversationData.conversations.find(function(c) {
                return c.id === convId;
            });

            if (!conv) return;

            window.currentConversation = convId;
            currentConversation = conv;

            // 更新会话列表激活状态
            $('.conversation-item').removeClass('active');
            $('.conversation-item[data-id="' + convId + '"]').addClass('active');

            // 更新聊天头部
            $('#chat-username').html(conv.user.name + '<small style="color: #999; font-weight: normal; margin-left: 20px">' + conv.user.email + '</small>');

            const statusText = conv.status === 'pending' ? '待处理' :
                             conv.status === 'processing' ? '处理中' :
                             conv.status === 'closed' ? '已关闭' : '待处理';

            $('#chat-status').text(conv.platform + ' · ' + statusText);

            // 更新聊天信息显示
            window.updateChatInfoDisplay();

            // 渲染消息
            renderMessages(conv.messages);
        }

        // 渲染消息
        function renderMessages(messages) {
            const $chatBody = $('#chat-messages');
            $chatBody.empty();
            
            messages.forEach(function(msg) {
                const senderClass = msg.sender === 'customer' ? 'message-customer' : 'message-agent';
                const sentimentHtml = msg.sentiment ? 
                    '<span class="sentiment-tag sentiment-' + msg.sentiment + '">' + 
                    (msg.sentiment === 'negative' ? '负面' : msg.sentiment === 'positive' ? '正面' : '中性') + '</span>' : '';
                
                const html = '<div class="message ' + senderClass + '">' +
                    '<div class="d-flex align-items-center">' +
                    '<div class="message-content">' + msg.content + '</div>' +
                    sentimentHtml +
                    '</div>' +
                    '<div class="message-time">' + msg.time + '</div>' +
                    '</div>';
                
                $chatBody.append(html);
            });
            
            // 滚动到底部
            $chatBody.scrollTop($chatBody[0].scrollHeight);
        }

        // 会话搜索
        function performSearch() {
            const searchTerm = $('#conversation-search').val().toLowerCase();
            
            $('.conversation-item').each(function() {
                const user = $(this).find('.conversation-user').text().toLowerCase();
                const message = $(this).find('.conversation-message').text().toLowerCase();
                
                if (user.includes(searchTerm) || message.includes(searchTerm)) {
                    $(this).show();
                } else {
                    $(this).hide();
                }
            });
        }

        $('#conversation-search').on('keyup', function() {
            performSearch();
        });

        $('#search-btn').click(function() {
            performSearch();
        });

        // 状态筛选
        $('.sidebar-header .dropdown-item').click(function(e) {
            e.preventDefault();
            const statusText = $(this).text();
            
            if (statusText === '全部') {
                $('.conversation-item').show();
            } else {
                $('.conversation-item').hide();
                $('.conversation-status:contains("' + statusText + '")').closest('.conversation-item').show();
            }
            
            // 更新按钮文字
            $(this).closest('.dropdown').find('button').text(statusText);
        });

        // 发送消息
        $('#send-btn').click(function() {
            const message = $('#message-input').val();
            if (!message || !currentConversation) return;
            
            // 添加消息到数据
            currentConversation.messages.push({
                sender: 'agent',
                content: message,
                time: '今天 ' + new Date().toLocaleTimeString('zh-CN', { hour: '2-digit', minute: '2-digit' })
            });
            
            // 更新最后消息
            currentConversation.lastMessage = message;
            currentConversation.lastMessageTime = '今天 ' + new Date().toLocaleTimeString('zh-CN', { hour: '2-digit', minute: '2-digit' });
            
            // 重新渲染
            renderMessages(currentConversation.messages);
            renderConversationList();
            
            // 清空输入框
            $('#message-input').val('');
        });

        $('#message-input').keypress(function(e) {
            if (e.which === 13) {
                $('#send-btn').click();
            }
        });

        // 智能推荐按钮
        $('#recommend-btn').click(function() {
            const $recommendationArea = $('#recommendation-area');
            if ($recommendationArea.length) {
                $recommendationArea.toggle();
            } else {
                const html = '<div class="recommendation-area" id="recommendation-area">' +
                    '<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px;">' +
                    '<div class="recommendation-title">智能回复推荐</div>' +
                    '<button class="close-recommendation" style="background: none; border: none; color: #666; font-size: 16px; cursor: pointer;">' +
                    '<i class="fas fa-times"></i>' +
                    '</button>' +
                    '</div>' +
                    '<div class="recommendation-item">' +
                    '<div style="display: flex; align-items: flex-start;">' +
                    '<button class="copy-recommendation" style="margin-right: 8px; background: none; border: 1px solid #ddd; border-radius: 3px; padding: 2px 6px; font-size: 12px; cursor: pointer;">' +
                    '<i class="fas fa-copy"></i>' +
                    '</button>' +
                    '<span>Thank you for reaching out. We are sorry to hear about the issue. Could you please provide your order ID and a video of the problem? We will arrange a replacement for you.</span>' +
                    '</div>' +
                    '</div>' +
                    '<div class="recommendation-item">' +
                    '<div style="display: flex; align-items: flex-start;">' +
                    '<button class="copy-recommendation" style="margin-right: 8px; background: none; border: 1px solid #ddd; border-radius: 3px; padding: 2px 6px; font-size: 12px; cursor: pointer;">' +
                    '<i class="fas fa-copy"></i>' +
                    '</button>' +
                    '<span>I understand your concern. Let me check your order details and provide you with the best solution.</span>' +
                    '</div>' +
                    '</div>' +
                    '<div class="recommendation-item">' +
                    '<div style="display: flex; align-items: flex-start;">' +
                    '<button class="copy-recommendation" style="margin-right: 8px; background: none; border: 1px solid #ddd; border-radius: 3px; padding: 2px 6px; font-size: 12px; cursor: pointer;">' +
                    '<i class="fas fa-copy"></i>' +
                    '</button>' +
                    '<span>We take product quality seriously. Please share your order information and we will process your request promptly.</span>' +
                    '</div>' +
                    '</div>' +
                    '</div>';
                
                $('body').append(html);
            }
        });

        // 关闭推荐区域
        $(document).on('click', '.close-recommendation', function() {
            $(this).closest('.recommendation-area').remove();
        });

        // 复制推荐回复
        $(document).on('click', '.copy-recommendation', function(e) {
            e.stopPropagation();
            const text = $(this).next('span').text();
            navigator.clipboard.writeText(text).then(function() {
                // 复制成功
            }).catch(function(err) {
                // 复制失败
            });
        });

        // 推荐回复点击填充
        $(document).on('click', '.recommendation-item', function() {
            const text = $(this).find('span').text();
            $('#message-input').val(text);
        });

        // 初始化
        $(document).ready(function() {
            // 会话状态筛选
            // 筛选函数
            function filterConversations() {
                $('.conversation-item').each(function() {
                    const convId = parseInt($(this).data('id'));
                    const conv = conversationData.conversations.find(function(c) {
                        return c.id === convId;
                    });
                    if (!conv) {
                        $(this).hide();
                        return;
                    }

                    let show = true;

                    // 状态筛选 - 支持多选
                    if (currentFilter.status.length > 0 && !currentFilter.status.includes(conv.status)) {
                        show = false;
                    }

                    // 分类筛选 - Ant Design Cascader multiple模式返回数组的数组
                    if (show && currentFilter.category.length > 0) {
                        const selectedCategories = currentFilter.category.flat();
                        const convCategory = conv.category;
                        if (!selectedCategories.includes(convCategory)) {
                            const convCategoryParts = convCategory.split('-');
                            const matched = selectedCategories.some(function(selected) {
                                const selectedParts = selected.split('-');
                                if (selectedParts.length === 1 && convCategoryParts[0] === selectedParts[0]) {
                                    return true;
                                }
                                if (selectedParts.length === 2 && convCategoryParts[0] === selectedParts[0] && convCategoryParts[1] === selectedParts[1]) {
                                    return true;
                                }
                                return false;
                            });
                            if (!matched) {
                                show = false;
                            }
                        }
                    }

                    $(this).toggle(show);
                });
            }

            renderConversationList();
            updateChatHeaderForChannel();
            // 默认选中第一个Amazon会话
            const firstAmazonConv = conversationData.conversations.find(function(c) {
                return c.platform === 'Amazon';
            });
            if (firstAmazonConv) {
                selectConversation(firstAmazonConv.id);
            }
        });
    </script>
</body>
